{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "headroom init hook ensure --profile init-user --marker headroom-init-codex",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "headroom init hook ensure --profile init-user --marker headroom-init-codex",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
